---
import { siteConfig, getSocialLinks } from '../config/site';
import { Separator } from './ui/separator';
import ContentContainer from './ContentContainer.astro';

const socialLinks = getSocialLinks();
const year = new Date().getFullYear();
---

<footer class="relative border-t border-border/70 py-16 mt-0" role="contentinfo">
  <ContentContainer>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">
      <!-- Brand column -->
      <div>
        <p class="text-lg font-bold tracking-tight text-foreground mb-3">{siteConfig.name}</p>
        {siteConfig.footerBlurb && (
          <p class="text-sm text-muted-foreground leading-relaxed max-w-xs">
            {siteConfig.footerBlurb}
          </p>
        )}
      </div>
      <!-- Nav column -->
      <nav class="flex flex-col gap-2" aria-label="Footer">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-muted-foreground mb-1">Pages</p>
        {siteConfig.footerNavigation.map((item) => (
          <a
            href={item.href}
            class="text-sm text-muted-foreground hover:text-foreground transition-colors"
            aria-label={`Go to ${item.name} page`}
          >
            {item.name}
          </a>
        ))}
      </nav>
      <!-- Social column -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-muted-foreground mb-3">Connect</p>
        <div class="flex gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted-foreground hover:text-foreground transition-colors"
              aria-label={link.name}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d={link.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
    <Separator className="my-6" />
    <div class="flex flex-col sm:flex-row justify-between items-center gap-2">
      <p class="text-muted-foreground text-xs">
        &copy; {year} {siteConfig.name}. All rights reserved.
      </p>
    </div>
  </ContentContainer>
</footer>
