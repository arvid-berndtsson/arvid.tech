---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentContainer from '../components/ContentContainer.astro';
import ProseContent from '../components/ProseContent.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout
  title="Privacy Policy - Arvid Berndtsson"
  description="Privacy policy for arvid.tech"
>
  <div class="bg-background pt-8 pb-16">
    <ContentContainer>
      <header class="mb-10">
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-4">
          Privacy Policy
        </h1>
        <p class="text-sm text-muted-foreground">
          Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </header>

      <ProseContent>
        <h2>Overview</h2>
        <p>
          This website (arvid.tech) respects your privacy. This policy outlines how we handle your information.
        </p>

        <h2>Information Collection</h2>
        <p>
          We use Cloudflare Analytics to understand site usage. This is privacy-first analytics that doesn't use cookies or track personal information.
        </p>

        <h2>Cookies</h2>
        <p>
          This website does not use cookies for tracking purposes.
        </p>

        <h2>Third-Party Services</h2>
        <p>
          This site is hosted on Cloudflare Pages. Please refer to <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">Cloudflare's Privacy Policy</a> for more information.
        </p>

        <h2>Contact</h2>
        <p>
          If you have questions about this privacy policy, please contact me at <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.
        </p>
      </ProseContent>
    </ContentContainer>
  </div>
</BaseLayout>
