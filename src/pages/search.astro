---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentContainer from '../components/ContentContainer.astro';
import Search from 'astro-pagefind/components/Search';
---

<BaseLayout
  title="Search – Arvid Berndtsson"
  description="Search blog posts, projects, and experiences."
>
  <div class="bg-background relative overflow-hidden py-14 sm:py-16 pb-20">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute top-1/4 -right-32 h-64 w-64 rounded-full bg-amber-600/12 dark:bg-amber-600/8 blur-3xl animate-pulse-glow"></div>
      <div class="absolute -bottom-12 -left-20 h-56 w-56 rounded-full bg-amber-500/10 dark:bg-amber-600/8 blur-3xl animate-pulse-glow" style="animation-delay: 2s;"></div>
    </div>
    <ContentContainer>
      <div class="relative">
        <header class="mb-8">
          <p class="animate-fade-in-up text-xs font-semibold uppercase tracking-[0.2em] text-amber-800 dark:text-amber-400 mb-2">
            Find
          </p>
          <h1 class="animate-fade-in-up stagger-1 text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-2">
            Search
          </h1>
          <p class="animate-fade-in-up stagger-2 text-muted-foreground text-lg max-w-md">
            Search across blog posts, projects, and experiences.
          </p>
        </header>
        <div class="animate-fade-in-up stagger-3 min-h-[320px]">
          <Search id="search" className="min-h-[320px]" />
        </div>
      </div>
    </ContentContainer>
  </div>
</BaseLayout>
