---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import ProseContent from '../../components/ProseContent.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const experiences = await getCollection('experiences');
  return experiences.map((experience) => ({
    params: { slug: experience.id },
    props: { experience },
  }));
}

interface Props {
  experience: CollectionEntry<'experiences'>;
}

const { experience } = Astro.props;
const { Content } = await render(experience);
---

<BaseLayout
  title={`${experience.data.role} at ${experience.data.company} – Arvid Berndtsson`}
  description={experience.data.summary || ''}
>
  <div class="bg-background pt-8 pb-16">
    <ContentContainer innerTag="article">
      <header class="mb-12">
        <a 
          href="/experiences" 
          class="inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors mb-8"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to experiences
        </a>
        
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-3">
          {experience.data.role}
        </h1>
        
        <p class="text-lg font-medium text-muted-foreground mb-4">
          {experience.data.company}
        </p>

        <div class="flex items-center text-sm text-muted-foreground mb-6">
          <time>
            {experience.data.startDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
            {' \u2013 '}
            {experience.data.endDate 
              ? experience.data.endDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })
              : 'Present'
            }
          </time>
        </div>

        {experience.data.tags && experience.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {experience.data.tags.map((tag) => (
              <a 
                href={`/tags/${tag}`}
                class="inline-block px-2.5 py-1 text-xs font-medium bg-muted text-muted-foreground rounded-full hover:bg-orange-100 dark:hover:bg-orange-950/40 hover:text-orange-600 dark:hover:text-orange-400 transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </header>

      <ProseContent>
        <Content />
      </ProseContent>
    </ContentContainer>
  </div>
</BaseLayout>
