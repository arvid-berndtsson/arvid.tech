---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentContainer from '../components/ContentContainer.astro';
import { getCollection } from 'astro:content';
import { categoryLabels, sortProjectsByUpdatedDate, statusLabel } from '../lib/projects';

const tools = sortProjectsByUpdatedDate(await getCollection('projects'));
const recommendedTools = tools.filter((tool) => tool.data.featured).slice(0, 4);
const archivedTools = tools.filter((tool) => tool.data.status === 'archived');
const activeTools = tools.filter((tool) => tool.data.status !== 'archived');

const categories = [...new Set(tools.map((tool) => tool.data.category))];
const statuses = [...new Set(tools.map((tool) => tool.data.status))];
const languages = [...new Set(tools.map((tool) => tool.data.language))];

const itemListData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Tools catalog on arvid.tech',
  itemListElement: tools.map((tool, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `https://arvid.tech/projects/${tool.id}`,
    name: tool.data.title,
  })),
};
---

<BaseLayout
  title="Tools - Arvid Berndtsson"
  description="Tool catalog with offensive security, compliance, and product/application projects. Includes status and language filters, recommended starting points, and archived tools."
  structuredData={itemListData}
>
  <div class="bg-background pt-8 pb-16">
    <ContentContainer>
      <header class="mb-10">
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">Tools</h1>
        <p class="text-lg text-muted-foreground max-w-3xl">
          A practical catalog of tools and working prototypes. Use category, status, and language views to find what fits your use case.
        </p>
      </header>

      <section class="mb-10 rounded-2xl border border-border/60 bg-card p-6">
        <h2 class="text-2xl font-semibold tracking-tight mb-4">Filter views</h2>
        <div class="grid gap-4 md:grid-cols-3">
          <article>
            <h3 class="text-sm uppercase tracking-[0.14em] text-muted-foreground font-semibold mb-2">Category</h3>
            <ul class="space-y-1.5">
              {categories.map((category) => (
                <li><a href={`/projects/${category}`} class="text-orange-500 dark:text-orange-400 hover:underline">{categoryLabels[category]}</a></li>
              ))}
            </ul>
          </article>
          <article>
            <h3 class="text-sm uppercase tracking-[0.14em] text-muted-foreground font-semibold mb-2">Status</h3>
            <ul class="space-y-1.5">
              {statuses.map((status) => (
                <li>{statusLabel(status)}</li>
              ))}
            </ul>
          </article>
          <article>
            <h3 class="text-sm uppercase tracking-[0.14em] text-muted-foreground font-semibold mb-2">Language</h3>
            <ul class="space-y-1.5">
              {languages.map((language) => (
                <li>{language}</li>
              ))}
            </ul>
          </article>
        </div>
      </section>

      <section class="mb-10">
        <h2 class="text-2xl font-semibold tracking-tight mb-4">Start here</h2>
        <div class="grid gap-4 md:grid-cols-2">
          {recommendedTools.map((tool) => (
            <article class="rounded-xl border border-border/60 p-4">
              <a href={`/projects/${tool.id}`} class="font-semibold text-orange-500 dark:text-orange-400 hover:underline">{tool.data.title}</a>
              <p class="text-sm text-muted-foreground mt-2">{tool.data.summary}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="mb-10">
        <h2 class="text-2xl font-semibold tracking-tight mb-4">Tool catalog</h2>
        <div class="overflow-x-auto rounded-xl border border-border/60">
          <table class="w-full text-sm">
            <thead class="bg-muted/40 text-left">
              <tr>
                <th class="px-4 py-3 font-semibold">Tool</th>
                <th class="px-4 py-3 font-semibold">Category</th>
                <th class="px-4 py-3 font-semibold">Status</th>
                <th class="px-4 py-3 font-semibold">Language</th>
              </tr>
            </thead>
            <tbody>
              {activeTools.map((tool) => (
                <tr class="border-t border-border/50">
                  <td class="px-4 py-3">
                    <a href={`/projects/${tool.id}`} class="font-semibold text-orange-500 dark:text-orange-400 hover:underline">{tool.data.title}</a>
                  </td>
                  <td class="px-4 py-3">{categoryLabels[tool.data.category]}</td>
                  <td class="px-4 py-3">{statusLabel(tool.data.status)}</td>
                  <td class="px-4 py-3">{tool.data.language}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="mb-10">
        <h2 class="text-2xl font-semibold tracking-tight mb-4">Archived tools</h2>
        <ul class="space-y-2">
          {archivedTools.map((tool) => (
            <li>
              <a href={`/projects/${tool.id}`} class="text-orange-500 dark:text-orange-400 hover:underline">{tool.data.title}</a>
              <span class="text-muted-foreground"> ({statusLabel(tool.data.status)})</span>
            </li>
          ))}
        </ul>
      </section>

      <p class="text-muted-foreground">
        Found a bug or feature gap? Open an issue in the relevant repository from the project page links, or send a request via <a href="/contact" class="font-semibold text-orange-500 dark:text-orange-400 hover:underline">contact</a>.
      </p>
    </ContentContainer>
  </div>
</BaseLayout>
