---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentContainer from '../components/ContentContainer.astro';
import { getCollection } from 'astro:content';
import { toBlogSlug } from '../lib/content-slugs';

const securityPosts = (await getCollection('blog'))
  .filter((post) => {
    const tags = post.data.tags ?? [];
    return tags.some((tag) =>
      [
        'security',
        'compliance',
        'governance',
        'incident-response',
        'supply-chain',
        'privacy',
        'threat-modeling',
        'zero-trust',
      ].includes(tag),
    );
  })
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type ResearchTopic = 'Application Security' | 'Governance and Compliance' | 'Infrastructure and Architecture' | 'Security Leadership';

function topicForPost(tags: string[]): ResearchTopic {
  if (tags.some((tag) => ['supply-chain', 'threat-modeling', 'security', 'incident-response'].includes(tag))) {
    return 'Application Security';
  }
  if (tags.some((tag) => ['compliance', 'governance', 'iso-27001', 'soc2', 'privacy'].includes(tag))) {
    return 'Governance and Compliance';
  }
  if (tags.some((tag) => ['cloud', 'architecture', 'zero-trust', 'platform'].includes(tag))) {
    return 'Infrastructure and Architecture';
  }
  return 'Security Leadership';
}

const groupedByTopic = securityPosts.reduce<Record<ResearchTopic, typeof securityPosts>>(
  (acc, post) => {
    const topic = topicForPost(post.data.tags ?? []);
    acc[topic].push(post);
    return acc;
  },
  {
    'Application Security': [],
    'Governance and Compliance': [],
    'Infrastructure and Architecture': [],
    'Security Leadership': [],
  },
);

const itemListData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Security research on arvid.tech',
  itemListElement: securityPosts.map((post, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `https://arvid.tech/blog/${toBlogSlug(post.id)}`,
    name: post.data.title,
  })),
};
---

<BaseLayout
  title="Security Research - Arvid Berndtsson"
  description="Security research posts grouped by topic with summaries, publication dates, and practical takeaways."
  structuredData={itemListData}
>
  <div class="bg-background pt-8 pb-16">
    <ContentContainer>
      <header class="mb-10">
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">Security Research</h1>
        <p class="text-lg text-muted-foreground max-w-3xl">
          Research notes and field writeups across application security, compliance, architecture, and leadership.
        </p>
        <p class="text-sm text-muted-foreground max-w-3xl mt-3">
          Project categories and research topics are intentionally different: categories group build artifacts in <a href="/projects" class="font-semibold text-orange-500 dark:text-orange-400 hover:underline">projects</a>, while topics group written analysis across multiple categories.
        </p>
      </header>

      {Object.entries(groupedByTopic).map(([topic, posts]) => (
        posts.length > 0 && (
          <section class="mb-10">
            <h2 class="text-2xl font-semibold tracking-tight mb-4">{topic}</h2>
            <ul class="space-y-4">
              {posts.map((post) => (
                <li class="rounded-xl border border-border/60 p-4">
                  <a href={`/blog/${toBlogSlug(post.id)}`} class="font-semibold text-orange-500 dark:text-orange-400 hover:underline">{post.data.title}</a>
                  <p class="text-sm text-muted-foreground mt-1">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
                  <p class="mt-2">{post.data.summary ?? post.data.excerpt ?? 'No summary provided.'}</p>
                  <p class="mt-2 text-sm text-muted-foreground">
                    Takeaway: {(post.data.summary ?? post.data.excerpt ?? 'Read the full post for practical implementation guidance.').split('. ')[0]}.
                  </p>
                </li>
              ))}
            </ul>
          </section>
        )
      ))}

      <section class="mb-8">
        <h2 class="text-2xl font-semibold tracking-tight mb-3">Key findings and highlights</h2>
        <ul class="list-disc pl-5 space-y-2">
          <li>Most repeat incidents tie back to weak fundamentals in identity, dependency hygiene, and segmentation.</li>
          <li>Compliance succeeds faster when controls are mapped to engineering workflows rather than policy-only documents.</li>
          <li>Security architecture decisions become durable when they are tied to clear operational ownership.</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-semibold tracking-tight mb-3">Disclosure and contact</h2>
        <p class="text-muted-foreground">
          If you need coordinated disclosure for a potential vulnerability, use the <a href="/contact" class="font-semibold text-orange-500 dark:text-orange-400 hover:underline">contact page</a> and include clear reproduction details.
        </p>
      </section>
    </ContentContainer>
  </div>
</BaseLayout>
