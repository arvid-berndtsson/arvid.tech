---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import ProseContent from '../../components/ProseContent.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { siteConfig } from '../../config/site';
import { assertUniqueBlogSlugs, toBlogSlug } from '../../lib/content-slugs';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  assertUniqueBlogSlugs(posts.map((post) => post.id));
  return posts.map((post) => ({
    params: { slug: toBlogSlug(post.id) },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const authorName = Array.isArray(post.data.author)
  ? post.data.author[0]
  : post.data.author;
---

<BaseLayout
  title={`${post.data.title} – Arvid Berndtsson`}
  description={post.data.summary || post.data.excerpt || ''}
  type="article"
  publishedTime={post.data.date}
  author={authorName || siteConfig.name}
  tags={post.data.tags || []}
  noindex={post.data.noindex}
>
  <div class="bg-background pt-8 pb-16">
    <ContentContainer innerTag="article">
      <header class="mb-12">
        <a 
          href="/blog" 
          class="inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors mb-8"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to blog
        </a>
        
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-5">
          {post.data.title}
        </h1>
        
        <div class="flex items-center text-sm text-muted-foreground mb-6">
          <time>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {post.data.tags.map((tag) => (
              <a 
                href={`/tags/${tag}`}
                class="inline-block px-2.5 py-1 text-xs font-medium bg-muted text-muted-foreground rounded-full hover:bg-orange-100 dark:hover:bg-orange-950/40 hover:text-orange-600 dark:hover:text-orange-400 transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </header>

      <ProseContent>
        <Content />
      </ProseContent>
    </ContentContainer>
  </div>
</BaseLayout>
