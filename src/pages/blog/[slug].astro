---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import ProseContent from '../../components/ProseContent.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { siteConfig } from '../../config/site';
import { assertUniqueBlogSlugs, toBlogSlug } from '../../lib/content-slugs';
import { toImageSrc } from '../../lib/content-images';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  assertUniqueBlogSlugs(posts.map((post) => post.id));
  return posts.map((post) => ({
    params: { slug: toBlogSlug(post.id) },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const authorName = Array.isArray(post.data.author)
  ? post.data.author[0]
  : post.data.author;
const coverImage = toImageSrc(post.data.coverImage ?? post.data.featuredImage);
const coverImageAlt = post.data.coverImageAlt ?? '';
const coverImageCredit = post.data.coverImageCreditName && post.data.coverImageCreditUrl
  ? {
      name: post.data.coverImageCreditName,
      url: post.data.coverImageCreditUrl,
    }
  : null;
---

<BaseLayout
  title={`${post.data.title} - Arvid Berndtsson`}
  description={post.data.summary || post.data.excerpt || ''}
  image={coverImage}
  type="article"
  publishedTime={post.data.date}
  author={authorName || siteConfig.name}
  tags={post.data.tags || []}
  noindex={post.data.noindex}
>
  <div class="bg-background pt-8 pb-16">
    <ContentContainer innerTag="article">
      <header class="mb-12">
        <a 
          href="/blog" 
          class="inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors mb-8"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to blog
        </a>
        
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-5">
          {post.data.title}
        </h1>
        
        <div class="flex items-center text-sm text-muted-foreground mb-6">
          <time>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {post.data.tags.map((tag) => (
              <a 
                href={`/tags/${tag}`}
                class="inline-block px-2.5 py-1 text-xs font-medium bg-muted text-muted-foreground rounded-full hover:bg-orange-100 dark:hover:bg-orange-950/40 hover:text-orange-500 dark:hover:text-orange-400 transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        )}

        {coverImage && (
          <figure class="mt-8 overflow-hidden rounded-xl border border-border/60 bg-muted/30">
            <img
              src={coverImage}
              alt={coverImageAlt}
              width="1140"
              height="641"
              class="block aspect-video w-full object-cover"
            />
            {(post.data.featuredImageCaption || coverImageCredit) && (
              <figcaption class="px-4 py-3 text-xs leading-relaxed text-muted-foreground">
                {post.data.featuredImageCaption && <span>{post.data.featuredImageCaption}</span>}
                {post.data.featuredImageCaption && coverImageCredit && <span> </span>}
                {coverImageCredit && (
                  <span>
                    Photo by{' '}
                    <a
                      href={coverImageCredit.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-medium text-foreground underline decoration-orange-500 decoration-2 underline-offset-4 hover:text-orange-500 dark:hover:text-orange-400"
                    >
                      {coverImageCredit.name}
                    </a>
                  </span>
                )}
              </figcaption>
            )}
          </figure>
        )}
      </header>

      <ProseContent>
        <Content />
      </ProseContent>
    </ContentContainer>
  </div>
</BaseLayout>
