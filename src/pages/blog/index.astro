---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import { getCollection } from 'astro:content';
import { ContentCard } from '../../components/ContentCard';
import { toBlogSlug } from '../../lib/content-slugs';
import { toImageSrc } from '../../lib/content-images';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout 
  title="Blog – Arvid Berndtsson" 
  description="Articles, ideas, and reflections on information security, software development, and technology."
>
  <div class="bg-background pt-8 pb-16">
    <ContentContainer>
      <header class="mb-14">
        <p class="animate-fade-in-up text-xs font-semibold uppercase tracking-[0.2em] text-amber-800 dark:text-amber-400 mb-3">Blog</p>
        <h1 class="animate-fade-in-up stagger-1 text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-foreground mb-4">Blog</h1>
        <p class="animate-fade-in-up stagger-2 text-lg text-muted-foreground max-w-2xl">
          Articles, ideas, and reflections on information security, software development, and technology.
        </p>
      </header>

      <div class="animate-fade-in-up stagger-3 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.map((post) => (
          <article>
            <ContentCard
              variant="post"
              slug={toBlogSlug(post.id)}
              title={post.data.title}
              summary={post.data.summary ?? undefined}
              tags={post.data.tags ?? []}
              date={post.data.date.toISOString()}
              coverImage={toImageSrc(post.data.coverImage ?? post.data.featuredImage)}
              coverImageAlt={post.data.coverImageAlt ?? undefined}
              titleLevel="h2"
              showExtraTags={true}
            />
          </article>
        ))}
      </div>
    </ContentContainer>
  </div>
</BaseLayout>
