---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentContainer from '../components/ContentContainer.astro';
import { siteConfig } from '../config/site';
import { Card, CardContent } from '../components/ui/card';

const labelClass = 'text-xs font-semibold uppercase tracking-[0.2em] text-amber-800 dark:text-amber-400';
const metaLabelClass = 'text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground';
const socialLinkClass =
  'inline-flex items-center gap-2 rounded-full bg-muted/80 dark:bg-muted/60 px-4 py-2.5 text-sm font-medium text-foreground hover:bg-amber-100 hover:text-amber-800 dark:hover:bg-amber-900/40 dark:hover:text-amber-300 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2';
---

<BaseLayout
  title="Contact – Arvid Berndtsson"
  description="Get in touch for security consulting, software development, or collaboration opportunities."
>
  <div class="bg-background">
    <!-- Hero-style section -->
    <section class="relative overflow-hidden py-20 sm:py-28" aria-labelledby="contact-heading">
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 h-72 w-[600px] rounded-full bg-amber-600/12 dark:bg-amber-600/8 blur-3xl"></div>
      </div>
      <ContentContainer>
        <div class="relative">
          <p class={`animate-fade-in-up ${labelClass}`}>Say hello</p>
          <h1 id="contact-heading" class="animate-fade-in-up stagger-1 text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-foreground mt-2">
            Contact
          </h1>
          <p class="animate-fade-in-up stagger-2 mt-4 text-lg sm:text-xl text-muted-foreground max-w-2xl leading-relaxed">
            Get in touch for security consulting, software development, or collaboration opportunities.
          </p>
        </div>
      </ContentContainer>
    </section>

    <!-- Contact details -->
    <section class="border-t border-border/60 pt-16 sm:pt-20 pb-20 sm:pb-28" aria-label="Contact details">
      <ContentContainer>
        <p class={`animate-fade-in-up stagger-3 ${labelClass} mb-2`}>Reach out</p>
        <div class="animate-fade-in-up stagger-4 mb-14 max-w-md">
          <a
            href={`mailto:${siteConfig.email}`}
            class="group block rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
          >
            <Card className="border-border/60 card-interactive transition-colors hover:border-amber-500/30 dark:hover:border-amber-500/20">
              <CardContent className="pt-6 pb-6 px-6">
                <div
                  class="h-12 w-12 rounded-full bg-amber-100 dark:bg-amber-900/40 flex items-center justify-center mb-4"
                  aria-hidden="true"
                >
                  <svg
                    class="w-6 h-6 text-amber-800 dark:text-amber-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    />
                  </svg>
                </div>
                <p class={metaLabelClass + ' mb-1'}>Email</p>
                <p class="text-foreground font-semibold text-lg text-amber-800 dark:text-amber-400 transition-colors group-hover:text-amber-900 dark:group-hover:text-amber-300">
                  {siteConfig.email}
                </p>
              </CardContent>
            </Card>
          </a>
        </div>

        <div class="pt-10 border-t border-border/60">
          <p class={metaLabelClass + ' mb-4'}>Social</p>
          <div class="flex flex-wrap gap-3">
            <a
              href={siteConfig.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class={socialLinkClass}
            >
              <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                />
              </svg>
              GitHub
            </a>
            <a
              href={siteConfig.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class={socialLinkClass}
            >
              <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                />
              </svg>
              LinkedIn
            </a>
          </div>
        </div>
      </ContentContainer>
    </section>
  </div>
</BaseLayout>
