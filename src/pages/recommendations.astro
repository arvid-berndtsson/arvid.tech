---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentContainer from '../components/ContentContainer.astro';
import { RECOMMENDATIONS } from '../../data/recommendations';
import { RecommendationAvatar } from '../components/RecommendationAvatar';

const sortedRecommendations = [...RECOMMENDATIONS].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<BaseLayout
  title="Recommendations - Arvid Berndtsson"
  description="Recommendations from colleagues, teachers, and collaborators."
>
  <div class="bg-background relative overflow-hidden py-14 sm:py-16 pb-20">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute top-1/4 -right-32 h-64 w-64 rounded-full bg-orange-500/12 dark:bg-orange-500/8 blur-3xl animate-pulse-glow"></div>
      <div class="absolute -bottom-12 -left-20 h-56 w-56 rounded-full bg-orange-400/10 dark:bg-orange-500/8 blur-3xl animate-pulse-glow" style="animation-delay: 2s;"></div>
    </div>
    <ContentContainer>
      <div class="relative">
        <header class="mb-10">
          <h1 class="animate-fade-in-up stagger-1 text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-2">
            Recommendations
          </h1>
          <p class="animate-fade-in-up stagger-2 text-muted-foreground text-lg max-w-md">
            What colleagues, teachers, and collaborators have said about working with me.
          </p>
        </header>

        <div class="animate-fade-in-up stagger-3 space-y-5 sm:space-y-6">
          {sortedRecommendations.map((rec) => (
            <article class="recommendation-card rounded-xl border bg-muted/30 dark:bg-muted/20 px-5 py-6 sm:px-6 sm:py-7 relative">
              <span class="recommendation-quote-mark text-4xl sm:text-5xl leading-none font-serif select-none absolute top-5 right-5" data-testid="recommendation-quote-mark" aria-hidden="true">&ldquo;</span>
              <blockquote class="relative pr-8">
                <p class="recommendation-content-en text-foreground/90 leading-relaxed text-base sm:text-lg" data-original-language={rec.original_language ?? undefined}>
                  {rec.content}
                </p>
                {rec.content_original && rec.original_language && (
                  <p class="recommendation-content-original mt-4 text-muted-foreground italic hidden text-base sm:text-lg leading-relaxed" lang={rec.original_language}>
                    {rec.content_original}
                  </p>
                )}
              </blockquote>
              <footer class="mt-5 flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-center gap-3">
                  <RecommendationAvatar name={rec.name} />
                  <div>
                    <strong class="text-foreground font-semibold text-sm">{rec.name}</strong>
                    <p class="text-muted-foreground text-xs">
                      {rec.role}{rec.company ? ` at ${rec.company}` : ''}
                    </p>
                  </div>
                </div>
                <time class="text-xs text-muted-foreground" datetime={rec.date}>
                  {new Date(rec.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                </time>
              </footer>
              {rec.content_original && rec.original_language && (
                <div class="mt-4 pt-4 border-t border-border/60">
                  <button
                    type="button"
                    class="toggle-original text-xs font-medium text-foreground underline decoration-orange-500 decoration-2 underline-offset-4 hover:text-foreground dark:decoration-orange-400 transition-colors"
                    data-original-label={rec.original_language === 'sv' ? 'Swedish' : rec.original_language}
                    aria-label="Toggle original language version"
                  >
                    Show original ({rec.original_language === 'sv' ? 'Swedish' : rec.original_language})
                  </button>
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </ContentContainer>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.toggle-original').forEach((btn) => {
    const label = btn.getAttribute('data-original-label') ?? 'original';
    btn.addEventListener('click', () => {
      const article = btn.closest('article');
      if (!article) return;
      const contentEn = article.querySelector('.recommendation-content-en');
      const contentOriginal = article.querySelector('.recommendation-content-original');
      if (!contentEn || !contentOriginal) return;
      const isShowingOriginal = contentOriginal.classList.contains('hidden');
      contentOriginal.classList.toggle('hidden', !isShowingOriginal);
      contentEn.classList.toggle('hidden', isShowingOriginal);
      btn.textContent = isShowingOriginal ? 'Show English' : `Show original (${label})`;
    });
  });
</script>
