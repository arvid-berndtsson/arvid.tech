---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import { getCollection } from 'astro:content';
import { ContentCard } from '../../components/ContentCard';
import { categoryLabels, getFeaturedProjects, PROJECT_CATEGORIES, sortProjectsByUpdatedDate, statusLabel } from '../../lib/projects';

const allProjects = sortProjectsByUpdatedDate(await getCollection('projects'));
const featuredProjects = getFeaturedProjects(allProjects);
const archivedProjects = allProjects.filter((project) => project.data.status === 'archived');
const activeProjects = allProjects.filter((project) => project.data.status !== 'archived');
const statusOrder: Array<'active' | 'maintained' | 'archived'> = ['active', 'maintained', 'archived'];

const languageCounts = allProjects.reduce<Record<string, number>>((acc, project) => {
  acc[project.data.language] = (acc[project.data.language] ?? 0) + 1;
  return acc;
}, {});

const statusCounts = allProjects.reduce<Record<string, number>>((acc, project) => {
  acc[project.data.status] = (acc[project.data.status] ?? 0) + 1;
  return acc;
}, {});

const projectsByStatus = statusOrder.map((status) => ({
  status,
  label: statusLabel(status),
  projects: allProjects.filter((project) => project.data.status === status),
}));

const languages = Object.keys(languageCounts).sort((a, b) => languageCounts[b] - languageCounts[a]);
const projectsByLanguage = languages.map((language) => ({
  language,
  anchor: `language-${language.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`,
  projects: allProjects.filter((project) => project.data.language === language),
}));

const itemListData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Projects on arvid.tech',
  itemListElement: allProjects.map((project, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `https://arvid.tech/projects/${project.id}`,
    name: project.data.title,
  })),
};
---

<BaseLayout 
  title="Projects: Security, Compliance, and Products – Arvid Berndtsson" 
  description="Master index of projects at arvid.tech with category, status, and language grouping. Explore offensive security tools, compliance projects, and production apps."
  structuredData={itemListData}
>
  <div class="bg-background pt-8 pb-16">
    <ContentContainer>
      <header class="mb-10">
        <p class="animate-fade-in-up text-xs font-semibold uppercase tracking-[0.2em] text-amber-800 dark:text-amber-400 mb-3">Portfolio</p>
        <h1 class="animate-fade-in-up stagger-1 text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-foreground mb-4">
          Projects
        </h1>
        <p class="animate-fade-in-up stagger-2 text-lg text-muted-foreground max-w-2xl">
          Security tooling, compliance workflows, and shipped products/apps. Use the category pages for focused browsing or scan everything from this master index.
        </p>
      </header>

      <section class="mb-12 rounded-2xl border border-border/60 bg-card p-6">
        <h2 class="text-2xl font-semibold tracking-tight mb-4">Browse by category, status, and language</h2>
        <div class="grid gap-4 md:grid-cols-3">
          <article>
            <h3 class="text-sm uppercase tracking-[0.14em] text-muted-foreground font-semibold mb-2">Category</h3>
            <ul class="space-y-1.5">
              {PROJECT_CATEGORIES.map((category) => (
                <li>
                  <a class="text-foreground hover:text-orange-600 dark:hover:text-orange-400" href={`/projects/${category}`}>
                    {categoryLabels[category]} ({allProjects.filter((project) => project.data.category === category).length})
                  </a>
                </li>
              ))}
            </ul>
          </article>
          <article>
            <h3 class="text-sm uppercase tracking-[0.14em] text-muted-foreground font-semibold mb-2">Status</h3>
            <ul class="space-y-1.5">
              {Object.entries(statusCounts).map(([status, count]) => (
                <li>
                  <a class="text-foreground hover:text-orange-600 dark:hover:text-orange-400" href={`#status-${status}`}>
                    {statusLabel(status as 'active' | 'maintained' | 'archived')} ({count})
                  </a>
                </li>
              ))}
            </ul>
          </article>
          <article>
            <h3 class="text-sm uppercase tracking-[0.14em] text-muted-foreground font-semibold mb-2">Language</h3>
            <ul class="space-y-1.5">
              {Object.entries(languageCounts)
                .sort((a, b) => b[1] - a[1])
                .map(([language, count]) => (
                  <li>
                    <a class="text-foreground hover:text-orange-600 dark:hover:text-orange-400" href={`#language-${language.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>
                      {language} ({count})
                    </a>
                  </li>
                ))}
            </ul>
          </article>
        </div>
      </section>

      <section class="mb-12">
        <div class="flex items-baseline justify-between gap-4 mb-4">
          <h2 class="text-2xl font-semibold tracking-tight">Featured projects</h2>
          <a href="/tools" class="text-sm font-semibold text-orange-700 dark:text-orange-400 hover:underline">View tool catalog</a>
        </div>
        <div class="animate-fade-in-up stagger-3 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredProjects.map((project) => (
            <article>
              <ContentCard
                variant="project"
                slug={project.id}
                title={project.data.title}
                summary={project.data.summary}
                tags={project.data.tags}
                date={project.data.updatedDate.toISOString()}
                repoUrl={project.data.repoUrl ?? undefined}
                demoUrl={project.data.demoUrl ?? undefined}
                coverImage={project.data.coverImage ?? undefined}
                coverImageAlt={project.data.coverImageAlt ?? undefined}
                showExtraTags={true}
                summaryLines={3}
                titleLevel="h2"
              />
            </article>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold tracking-tight mb-4">All active and maintained projects</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {activeProjects.map((project) => (
            <article>
              <ContentCard
                variant="project"
                slug={project.id}
                title={project.data.title}
                summary={project.data.summary}
                tags={[categoryLabels[project.data.category], statusLabel(project.data.status), project.data.language, ...project.data.tags]}
                date={project.data.updatedDate.toISOString()}
                repoUrl={project.data.repoUrl ?? undefined}
                demoUrl={project.data.demoUrl ?? undefined}
                coverImage={project.data.coverImage ?? undefined}
                coverImageAlt={project.data.coverImageAlt ?? undefined}
                showExtraTags={true}
                summaryLines={3}
                titleLevel="h2"
              />
            </article>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold tracking-tight mb-4">Browse by status</h2>
        <div class="space-y-10">
          {projectsByStatus.map((group) => (
            <article id={`status-${group.status}`} class="scroll-mt-24">
              <h3 class="text-xl font-semibold tracking-tight mb-3">{group.label}</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {group.projects.map((project) => (
                  <ContentCard
                    variant="project"
                    slug={project.id}
                    title={project.data.title}
                    summary={project.data.summary}
                    tags={[categoryLabels[project.data.category], project.data.language, ...project.data.tags]}
                    date={project.data.updatedDate.toISOString()}
                    repoUrl={project.data.repoUrl ?? undefined}
                    demoUrl={project.data.demoUrl ?? undefined}
                    coverImage={project.data.coverImage ?? undefined}
                    coverImageAlt={project.data.coverImageAlt ?? undefined}
                    showExtraTags={true}
                    summaryLines={3}
                    titleLevel="h2"
                  />
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold tracking-tight mb-4">Browse by language</h2>
        <div class="space-y-10">
          {projectsByLanguage.map((group) => (
            <article id={group.anchor} class="scroll-mt-24">
              <h3 class="text-xl font-semibold tracking-tight mb-3">{group.language}</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {group.projects.map((project) => (
                  <ContentCard
                    variant="project"
                    slug={project.id}
                    title={project.data.title}
                    summary={project.data.summary}
                    tags={[categoryLabels[project.data.category], statusLabel(project.data.status), ...project.data.tags]}
                    date={project.data.updatedDate.toISOString()}
                    repoUrl={project.data.repoUrl ?? undefined}
                    demoUrl={project.data.demoUrl ?? undefined}
                    coverImage={project.data.coverImage ?? undefined}
                    coverImageAlt={project.data.coverImageAlt ?? undefined}
                    showExtraTags={true}
                    summaryLines={3}
                    titleLevel="h2"
                  />
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-semibold tracking-tight mb-3">Archived projects</h2>
        <p class="text-muted-foreground mb-4">
          These are still available for reference and historical context, and are clearly labeled as archived.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {archivedProjects.map((project) => (
            <article>
              <ContentCard
                variant="project"
                slug={project.id}
                title={`${project.data.title} (Archived)`}
                summary={project.data.summary}
                tags={[categoryLabels[project.data.category], statusLabel(project.data.status), project.data.language, ...project.data.tags]}
                date={project.data.updatedDate.toISOString()}
                repoUrl={project.data.repoUrl ?? undefined}
                demoUrl={project.data.demoUrl ?? undefined}
                coverImage={project.data.coverImage ?? undefined}
                coverImageAlt={project.data.coverImageAlt ?? undefined}
                showExtraTags={true}
                summaryLines={3}
                titleLevel="h2"
              />
            </article>
          ))}
        </div>
        <p class="mt-6 text-sm text-muted-foreground">
          Looking for analysis and writeups? Browse <a href="/security-research" class="font-semibold text-orange-700 dark:text-orange-400 hover:underline">security research</a>.
        </p>
      </section>
    </ContentContainer>
  </div>
</BaseLayout>
