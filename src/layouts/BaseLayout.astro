---
import '../styles.css';
import '@pagefind/default-ui/css/ui.css';
import { SEO } from 'astro-seo';
import { siteConfig } from '../config/site';
import { NavBar } from '../components/NavBar';
import Footer from '../components/Footer.astro';
import { SearchModal } from '../components/SearchModal';

/** Root-relative path for Pagefind bundle (Cloudflare Pages serves static assets from dist) */
const pagefindBundlePath = '/pagefind/';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  tags?: string[];
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Arvid Berndtsson – Information Security Lead & Full‑Stack Developer",
  description = "I help companies keep data safe and build reliable software. Focus areas: ISO 27001, SOC 2, risk management, data loss prevention, incident response, and modern web apps. Based in Malmö & Varberg.",
  image = "/og-image.png",
  type = "website",
  publishedTime,
  modifiedTime,
  author = siteConfig.name,
  tags = [],
  noindex = false,
  structuredData: additionalStructuredData = [],
} = Astro.props;

const siteUrl = "https://arvid.tech";
const canonicalURL = new URL(Astro.url.pathname, Astro.site || siteUrl);
const imageUrl = new URL(image, siteUrl).toString();

// Structured data for Person
const personData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": siteConfig.name,
  "url": siteUrl,
  "image": imageUrl,
  "sameAs": [
    siteConfig.social.github,
    siteConfig.social.linkedin,
  ],
  "jobTitle": "Information Security Lead & Full-Stack Developer",
  "description": siteConfig.description,
  "email": siteConfig.email,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Malmö",
    "addressCountry": "SE"
  }
};

const webSiteData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.name,
  url: siteUrl,
  description: siteConfig.description,
};

// Article structured data (for blog posts)
const articleData = type === 'article' && publishedTime ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": imageUrl,
  "datePublished": publishedTime.toISOString(),
  "dateModified": modifiedTime?.toISOString() || publishedTime.toISOString(),
  "author": {
    "@type": "Person",
    "name": author,
  },
  "publisher": {
    "@type": "Person",
    "name": siteConfig.name,
    "logo": {
      "@type": "ImageObject",
      "url": new URL(siteConfig.logo, siteUrl).toString()
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.toString()
  },
  "keywords": tags.join(', ')
} : null;

// Build openGraph for astro-seo (basic + optional required; article only for type=article)
const openGraph: {
  basic: { title: string; type: string; image: string; url: string };
  optional: { description: string; siteName: string; locale: string };
  article?: { publishedTime: string; modifiedTime: string; authors: string[]; tags: string[] };
  image: { alt: string };
} = {
  basic: {
    title,
    type,
    image: imageUrl,
    url: canonicalURL.toString(),
  },
  optional: {
    description,
    siteName: siteConfig.name,
    locale: 'en_US',
  },
  image: { alt: title },
};
if (type === 'article' && publishedTime) {
  openGraph.article = {
    publishedTime: publishedTime.toISOString(),
    modifiedTime: (modifiedTime ?? publishedTime).toISOString(),
    authors: [author],
    tags,
  };
}

const extraStructuredData = Array.isArray(additionalStructuredData)
  ? additionalStructuredData
  : [additionalStructuredData];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <!-- Theme: apply dark class BEFORE first paint to prevent flash. Must be first in head. ?theme=light|dark overrides localStorage and prefers-color-scheme (for audits). -->
    <script is:inline>
      (function(){
        var q = typeof window !== 'undefined' && window.location && window.location.search;
        var themeParam = q && (q.indexOf('theme=light') !== -1 ? 'light' : q.indexOf('theme=dark') !== -1 ? 'dark' : null);
        var isDark = false;
        if (themeParam === 'dark') {
          isDark = true;
        } else if (themeParam !== 'light') {
          var t = typeof localStorage !== 'undefined' && localStorage.getItem('theme');
          isDark = t === 'dark' || (!t && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
        }
        if (isDark) {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
          document.documentElement.style.backgroundColor = '#111111';
        } else {
          document.documentElement.style.colorScheme = 'light';
          document.documentElement.style.backgroundColor = '#fafafa';
        }
      })();
    </script>
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL.toString()}
      noindex={noindex}
      charset="UTF-8"
      openGraph={openGraph}
      twitter={{
        card: 'summary_large_image',
        creator: '@arvidberndtsson',
        title,
        description,
        image: imageUrl,
        imageAlt: title,
      }}
      extend={{
        link: [
          { rel: 'icon', type: 'image/svg+xml', href: '/logo.svg' },
          { rel: 'sitemap', href: '/sitemap-index.xml' },
          { rel: 'preconnect', href: 'https://fonts.googleapis.com' },
          { rel: 'preconnect', href: 'https://fonts.gstatic.com', prefetch: false },
        ],
        meta: [
          { name: 'viewport', content: 'width=device-width, initial-scale=1.0' },
          { name: 'generator', content: Astro.generator },
          { name: 'author', content: author },
          ...(tags.length > 0 ? [{ name: 'keywords', content: tags.join(', ') }] : []),
        ],
      }}
    />
    <!-- Structured Data (astro-seo does not emit JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(personData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteData)} />
    {articleData && <script type="application/ld+json" set:html={JSON.stringify(articleData)} />}
    {extraStructuredData
      .filter((item) => Object.keys(item).length > 0)
      .map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))}
  </head>
  <body class="antialiased bg-background text-foreground">
    <div class="min-h-screen flex flex-col">
      <NavBar client:load siteName={siteConfig.name} navigation={siteConfig.navigation} currentPath={Astro.url.pathname} />
      <main class="flex-1 pt-16">
        <slot />
      </main>
      <Footer />
    </div>
    <SearchModal client:load bundlePath={pagefindBundlePath} />
    <script is:inline>
      /* Theme toggle listeners (dark class already applied in <head>) */
      (function() {
        function bindToggle() {
          document.querySelectorAll('#theme-toggle, #theme-toggle-mobile').forEach(function(btn) {
            btn.addEventListener('click', function() {
              var isDark = document.documentElement.classList.toggle('dark');
              document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
              document.documentElement.style.backgroundColor = isDark ? '#111111' : '#fafafa';
              try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch(e) {}
            });
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', bindToggle);
        } else {
          bindToggle();
        }
      })();
      /* Cmd+K (Mac) / Ctrl+K (Windows) → open search modal (skip when focus is in input/textarea) */
      document.addEventListener('keydown', function (e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          var t = e.target;
          var tag = t && t.tagName ? t.tagName.toLowerCase() : '';
          var editable = tag === 'input' || tag === 'textarea' || (t && t.isContentEditable);
          if (!editable) {
            e.preventDefault();
            window.dispatchEvent(new CustomEvent('open-search'));
          }
        }
      });
    </script>
  </body>
</html>
